# ─── Base de datos ───────────────────────────────────────────────────────────
# URL de conexión a PostgreSQL (formato Prisma)
DATABASE_URL="postgresql://smart_chef_user:smart_chef_pass@localhost:5432/smart_chef_db"

# ─── Autenticación ───────────────────────────────────────────────────────────
# Secreto para firmar los tokens JWT (mínimo 32 caracteres en producción)
JWT_SECRET="cambia_este_secreto_por_uno_seguro_en_produccion"
# Duración del token de acceso
JWT_EXPIRES_IN="15m"

# ─── Servidor ────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── CORS ────────────────────────────────────────────────────────────────────
# Whitelist de orígenes permitidos, separados por comas. Fuera de producción,
# además se permite automáticamente cualquier origen en rangos de IP privada
# (10.x, 172.16-31.x, 192.168.x) para facilitar el acceso desde otros
# dispositivos de tu LAN sin tener que listar cada IP aquí.
CORS_ORIGIN="http://localhost:5173"
